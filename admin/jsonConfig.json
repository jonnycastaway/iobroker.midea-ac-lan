{
    "type": "panel",
    "items": {
        "cloudEmail": {
            "type": "text",
            "label": "Midea Cloud Email",
            "placeholder": "your@email.com",
            "sm": 12,
            "md": 6,
            "lg": 6
        },
        "cloudPassword": {
            "type": "password",
            "label": "Midea Cloud Password",
            "placeholder": "Password",
            "sm": 12,
            "md": 6,
            "lg": 6
        },
        "refreshInterval": {
            "type": "number",
            "label": "Refresh Interval (seconds)",
            "min": 10,
            "max": 300,
            "default": 30,
            "sm": 12,
            "md": 6,
            "lg": 6
        },
        "devices": {
            "type": "text",
            "label": "IP Addresses (one per line)",
            "placeholder": "192.168.1.100\n192.168.1.101",
            "sm": 12,
            "md": 12,
            "lg": 12
        },
        "info": {
            "type": "staticText",
            "text": "Enter IP addresses of your AC devices. Token/Key will be fetched automatically from Midea Cloud using the credentials above.",
            "sm": 12,
            "md": 12,
            "lg": 12
        }
    }
}