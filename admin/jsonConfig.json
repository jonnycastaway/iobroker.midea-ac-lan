{
    "type": "panel",
    "items": {
        "_info": {
            "type": "staticText",
            "text": "Midea AC LAN Adapter - Trage die Gerätedaten ein"
        },
        "refreshInterval": {
            "type": "number",
            "label": "Refresh Interval (Sekunden)",
            "min": 10,
            "max": 300,
            "default": 30
        },
        "deviceId": {
            "type": "text",
            "label": "Device ID",
            "placeholder": "z.B. 153931629271567"
        },
        "deviceName": {
            "type": "text",
            "label": "Gerätename (optional)",
            "placeholder": "z.B. Wohnzimmer Klimaanlage"
        },
        "ipAddress": {
            "type": "text",
            "label": "IP Adresse",
            "placeholder": "z.B. 192.168.66.45"
        },
        "port": {
            "type": "number",
            "label": "Port",
            "default": 6444,
            "min": 1,
            "max": 65535
        },
        "token": {
            "type": "text",
            "label": "Token",
            "placeholder": "64 Zeichen Hex-String"
        },
        "key": {
            "type": "text",
            "label": "Key",
            "placeholder": "64 Zeichen Hex-String"
        },
        "model": {
            "type": "text",
            "label": "Model (optional)",
            "placeholder": "z.B. 00000Q15"
        },
        "subtype": {
            "type": "number",
            "label": "Subtype (optional)",
            "default": 0
        },
        "_help": {
            "type": "staticText",
            "text": "Hinweis: Token und Key erhältst du aus der Home Assistant midea_ac_lan Integration (.storage/midea_ac_lan/devices.json)"
        }
    }
}